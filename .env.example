# ExpressLane Docker environment variables
# Copy this file to .env and uncomment the lines below to enable HTTPS.
#
# Steps:
#   1. mkdir -p certs
#   2. cp /path/to/fullchain.pem certs/fullchain.pem
#   3. cp /path/to/privkey.pem   certs/privkey.pem
#   4. Replace EXPRESSLANE_FQDN in the SSL config:
#      sed 's/EXPRESSLANE_FQDN/expresslane.example.com/g' \
#          deploy/nginx-docker-ssl.conf > deploy/nginx-docker-ssl-live.conf
#   5. Uncomment the lines below and update the path:
#
# NGINX_CONF=./deploy/nginx-docker-ssl-live.conf
# SECURE_COOKIES=true
